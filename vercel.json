{
  "buildCommand": "node scripts/generate-config.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "headers": [
    { "source": "/(.*)\\.js",   "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/(.*)\\.html", "headers": [{ "key": "Cache-Control", "value": "no-store" }] },
    { "source": "/(.*)\\.css",  "headers": [{ "key": "Cache-Control", "value": "no-store" }] }
  ]
}
